@{
    ViewBag.Title = "Web Chăm Só Thú Cưng";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<style>
    body, html {
        height: 100%;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    /* Hero Video Background */
    .hero-video-wrapper {
        position: relative;
        width: 100%;
        max-height: 500px;
        overflow: hidden;
        margin-bottom: 40px;
    }
    .hero-video-wrapper video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Tiêu đề mục */
    .section-title {
        text-align: center;
        margin-bottom: 30px;
        font-weight: 700;
        color: #924bd5; /* Màu hồng cam thân thiện với pet shop */
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Product Card Styles */
    .pet-product-card {
        background: #fff;
        border-radius: 15px;
        padding: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: all 0.3s ease-in-out;
        height: 100%;
        display: flex;
        flex-direction: column;
        border: 1px solid #f1f1f1;
    }

    .pet-product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .pet-product-card .imgPart {
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 15px;
        text-align: center;
        height: 220px; /* Cố định chiều cao ảnh */
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #fafafa;
    }

    .pet-product-card .imgPart img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        transition: transform 0.3s;
    }

    .pet-product-card:hover .imgPart img {
        transform: scale(1.05);
    }

    .pet-product-card .titleProduct {
        font-size: 16px;
        font-weight: 600;
        color: #333;
        margin-bottom: 10px;
        text-align: center;
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .pet-product-card .titleProduct:hover {
        color: #924bd5;
    }

    .pet-product-card .price {
        color: #924bd5;
        font-weight: bold;
        font-size: 18px;
        text-align: center;
        margin-bottom: 15px;
    }

    /* Nút Thêm Giỏ Hàng */
    .btn-add-cart {
        display: block;
        width: 100%;
        text-align: center;
        background-color: #924bd5;
        color: white;
        padding: 10px;
        border-radius: 25px;
        text-decoration: none;
        font-weight: 600;
        transition: background-color 0.3s;
        margin-top: auto; /* Đẩy nút xuống đáy card */
    }

    .btn-add-cart:hover {
        background-color: #ff4757;
        color: white;
        text-decoration: none;
    }
</style>

<link href="~/Content/sanpham.css" rel="stylesheet" />
<link rel="stylesheet" href="~/Content/jquery.fancybox.min.css" />

