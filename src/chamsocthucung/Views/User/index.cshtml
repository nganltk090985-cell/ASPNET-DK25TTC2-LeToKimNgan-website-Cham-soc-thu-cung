        </section>
        *@

        <section id="home-collections" class="mb-5">
            <div class="secMainContent">
                <div class="text-center mb-4">
                    <div class="stylizedIcon mb-2">
                        <img alt="item" src="~/images/item_1MM.png" style="max-width: 50px;">
                    </div>
                    <h2 class="section-title">Thú Cưng Nổi Bật</h2>
                </div>

                <div class="row">
                    @foreach (var i in Model)
                    {
                        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                            <div class="pet-product-card">
                                <a href="@Url.Action("Chitiet", "User", new { id = i.MASP })" class="imgPart">
                                    <img alt="@i.TENSP" src="@Url.Content("~/img/" + @i.HINHANH)">
                                </a>

                                <a href="@Url.Action("Chitiet", "User", new { id = i.MASP })" style="text-decoration: none;">
                                    <p class="titleProduct" title="@i.TENSP">@i.TENSP</p>
                                </a>

                                <div class="price">
                                    @String.Format("{0:0,0}", i.DONGIABAN)đ
                                </div>

                                <a class="btn-add-cart" href="@Url.Action("ThemGiohang", "GioHang", new { @iMASP = i.MASP, @strURL = Request.Url.ToString() })" title="Thêm Giỏ Hàng">
                                    Thêm Giỏ Hàng
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>

    </main>
</div>

